# ============================================================
# Python bot — LOCAL development environment
# Copia este archivo como .env y ajusta los valores
# ============================================================

# DB local (Supabase local: corre `supabase start` desde la raiz del repo)
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# Flask
FLASK_DEBUG="True"
FLASK_API_BASE_URL="http://localhost:8000"
ADMIN_API_KEY="local-admin-key-change-in-prod"

# OpenAI
OPENAI_API_KEY=""

# WhatsApp (no requerido en local con MOCK_MODE=true)
MOCK_MODE="true"
ACCESS_TOKEN=""
APP_ID=""
APP_SECRET=""
RECIPIENT_WAID=""
PHONE_NUMBER_ID=""
VERIFY_TOKEN="local-verify-token"
VERSION="v18.0"

# Tracing
TRACER_TYPE="console"
TRACE_LOG_PII="false"
