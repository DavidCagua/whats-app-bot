{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn --bind 0.0.0.0:$PORT --timeout 120 --workers 2 --threads 4 --worker-class gthread --graceful-timeout 30 run:app",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100
  }
}
