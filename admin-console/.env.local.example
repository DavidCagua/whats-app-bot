# ============================================================
# admin-console — LOCAL development environment
# Copia este archivo como .env y ajusta los valores
# ============================================================

# DB local (Supabase local: corre `supabase start` desde la raiz del repo)
DATABASE_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="local-secret-change-in-prod"

# Flask (Python bot corriendo en local)
FLASK_API_BASE_URL="http://localhost:8000"
ADMIN_API_KEY="local-admin-key-change-in-prod"
