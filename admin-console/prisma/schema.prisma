generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model businesses {
  id                          String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                        String                        @db.VarChar(255)
  business_type               String?                       @default("barberia") @db.VarChar(50)
  settings                    Json?                         @default("{}")
  is_active                   Boolean?                      @default(true)
  created_at                  DateTime                      @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime                      @default(now()) @db.Timestamptz(6)
  enabled_modules             String[]                      @default(["bookings", "orders", "products", "promotions", "services", "staff"])
  bookings                    bookings[]
  business_agents             business_agents[]
  business_availability       business_availability[]
  business_customers          business_customers[]
  conversation_agent_settings conversation_agent_settings[]
  conversation_daily_analyses conversation_daily_analyses[]
  conversation_sessions       conversation_sessions[]
  conversations               conversations[]
  order_counters              order_counters[]
  orders                      orders[]
  products                    products[]
  promotions                  promotions[]
  services                    services[]
  staff_members               staff_members[]
  user_businesses             user_businesses[]
  whatsapp_numbers            whatsapp_numbers[]

  @@index([is_active], map: "idx_businesses_is_active")
}

model business_agents {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id String     @db.Uuid
  agent_type  String     @db.VarChar(50)
  enabled     Boolean?   @default(true)
  priority    Int?       @default(100)
  config      Json?      @default("{}")
  created_by  String?    @db.Uuid
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users?     @relation(fields: [created_by], references: [id], onUpdate: NoAction)

  @@unique([business_id, agent_type])
  @@index([business_id], map: "idx_business_agents_business_id")
  @@index([enabled], map: "idx_business_agents_enabled")
}

model conversation_agent_settings {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id    String     @db.Uuid
  whatsapp_id    String     @db.VarChar(50)
  agent_enabled  Boolean    @default(true)
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime   @default(now()) @db.Timestamptz(6)
  handoff_reason String?
  businesses     businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, whatsapp_id])
  @@index([business_id], map: "idx_conversation_agent_settings_business_id")
  @@index([whatsapp_id], map: "idx_conversation_agent_settings_whatsapp_id")
  @@index([agent_enabled], map: "idx_conversation_agent_settings_agent_enabled")
  @@index([handoff_reason], map: "idx_conversation_agent_settings_handoff_reason")
}

model conversation_attachments {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id    Int
  type               String        @db.VarChar(20)
  content_type       String?       @db.VarChar(255)
  provider_media_url String?
  provider_media_id  String?       @db.VarChar(255)
  url                String?
  size_bytes         BigInt?
  duration_sec       Decimal?      @db.Decimal(10, 2)
  transcript         String?
  provider_metadata  Json?         @default("{}")
  created_at         DateTime      @default(now()) @db.Timestamptz(6)
  updated_at         DateTime      @default(now()) @db.Timestamptz(6)
  conversations      conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([conversation_id], map: "idx_conversation_attachments_conversation_id")
  @@index([type], map: "idx_conversation_attachments_type")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversations {
  id                       Int                        @id @default(autoincrement())
  whatsapp_id              String                     @db.VarChar(50)
  message                  String
  role                     String                     @db.VarChar(20)
  timestamp                DateTime                   @default(now()) @db.Timestamptz(6)
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  business_id              String                     @db.Uuid
  whatsapp_number_id       String?                    @db.Uuid
  agent_type               String?                    @db.VarChar(50)
  message_type             String?                    @default("text") @db.VarChar(20)
  conversation_attachments conversation_attachments[]
  businesses               businesses                 @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  whatsapp_numbers         whatsapp_numbers?          @relation(fields: [whatsapp_number_id], references: [id], onUpdate: NoAction)

  @@index([business_id], map: "idx_conversations_business_id")
  @@index([whatsapp_number_id], map: "idx_conversations_whatsapp_number_id")
  @@index([timestamp], map: "idx_conversations_timestamp")
  @@index([whatsapp_id], map: "idx_conversations_whatsapp_id")
}

model customers {
  id                 Int                  @id @default(autoincrement())
  whatsapp_id        String               @unique @db.VarChar(50)
  name               String               @db.VarChar(100)
  age                Int?
  address            String?
  phone              String?              @db.VarChar(50)
  payment_method     String?              @db.VarChar(100)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  bookings           bookings[]
  business_customers business_customers[]
  orders             orders[]

  @@index([whatsapp_id], map: "idx_customers_whatsapp_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model user_businesses {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String     @db.Uuid
  business_id String     @db.Uuid
  role        String?    @default("staff") @db.VarChar(50)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, business_id])
  @@index([business_id], map: "idx_user_businesses_business_id")
  @@index([user_id], map: "idx_user_businesses_user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String            @unique @db.VarChar(255)
  password_hash   String
  full_name       String?           @db.VarChar(255)
  is_active       Boolean?          @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  role            String?           @default("staff") @db.VarChar(50)
  business_agents business_agents[]
  staff_members   staff_members[]
  user_businesses user_businesses[]

  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model whatsapp_numbers {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id     String          @db.Uuid
  phone_number_id String?         @db.VarChar(255)
  phone_number    String          @db.VarChar(50)
  is_active       Boolean?        @default(true)
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime        @default(now()) @db.Timestamptz(6)
  display_name    String?         @db.VarChar(255)
  conversations   conversations[]
  businesses      businesses      @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, phone_number], map: "whatsapp_numbers_business_phone_unique")
  @@index([business_id], map: "idx_whatsapp_numbers_business_id")
  @@index([is_active], map: "idx_whatsapp_numbers_is_active")
  @@index([phone_number_id], map: "idx_whatsapp_numbers_phone_number_id")
}

model products {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id          String                 @db.Uuid
  name                 String                 @db.VarChar(255)
  description          String?
  price                Decimal                @db.Decimal(12, 2)
  currency             String?                @default("COP") @db.VarChar(10)
  sku                  String?                @db.VarChar(50)
  is_active            Boolean?               @default(true)
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  category             String?                @db.VarChar(50)
  tags                 String[]               @default([])
  metadata             Json                   @default("{}")
  embedding            Unsupported("vector")?
  promo_only           Boolean                @default(false)
  order_items          order_items[]
  businesses           businesses             @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  promotion_components promotion_components[]

  @@index([business_id], map: "idx_products_business_id")
  @@index([category], map: "idx_products_category")
  @@index([is_active], map: "idx_products_is_active")
  @@index([embedding], map: "idx_products_embedding_cosine")
  @@index([metadata(ops: JsonbPathOps)], map: "idx_products_metadata_gin", type: Gin)
  @@index([tags], map: "idx_products_tags_gin", type: Gin)
}

model orders {
  id                          String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id                 String                        @db.Uuid
  customer_id                 Int?
  whatsapp_id                 String?                       @db.VarChar(50)
  status                      order_status                  @default(pending)
  total_amount                Decimal                       @default(0) @db.Decimal(12, 2)
  notes                       String?
  created_at                  DateTime                      @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime                      @default(now()) @db.Timestamptz(6)
  delivery_address            String?
  contact_phone               String?
  payment_method              String?
  cancellation_reason         String?
  confirmed_at                DateTime?                     @db.Timestamptz(6)
  completed_at                DateTime?                     @db.Timestamptz(6)
  cancelled_at                DateTime?                     @db.Timestamptz(6)
  promo_discount_amount       Decimal                       @default(0) @db.Decimal(12, 2)
  fulfillment_type            String                        @default("delivery")
  display_number              Int
  display_date                DateTime                      @db.Date
  ready_at                    DateTime?                     @db.Timestamptz(6)
  conversation_daily_analyses conversation_daily_analyses[]
  order_items                 order_items[]
  order_promotions            order_promotions[]
  businesses                  businesses                    @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers                   customers?                    @relation(fields: [customer_id], references: [id], onUpdate: NoAction)

  @@unique([business_id, display_date, display_number], map: "orders_business_display_unique")
  @@index([business_id], map: "idx_orders_business_id")
  @@index([customer_id], map: "idx_orders_customer_id")
  @@index([status], map: "idx_orders_status")
  @@index([created_at], map: "idx_orders_created_at")
  @@index([fulfillment_type], map: "idx_orders_fulfillment_type")
  @@index([business_id, display_date], map: "idx_orders_business_display_date")
}

model order_counters {
  business_id  String     @db.Uuid
  display_date DateTime   @db.Date
  last_value   Int        @default(0)
  businesses   businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([business_id, display_date])
}

model order_items {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id       String      @db.Uuid
  product_id     String      @db.Uuid
  quantity       Int
  unit_price     Decimal     @db.Decimal(12, 2)
  line_total     Decimal     @db.Decimal(12, 2)
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  notes          String?
  promotion_id   String?     @db.Uuid
  promo_group_id String?     @db.Uuid
  orders         orders      @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products       products    @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  promotions     promotions? @relation(fields: [promotion_id], references: [id], onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order_id")
  @@index([product_id], map: "idx_order_items_product_id")
  @@index([promo_group_id], map: "idx_order_items_promo_group_id")
  @@index([promotion_id], map: "idx_order_items_promotion_id")
}

model business_availability {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id           String         @db.Uuid
  day_of_week           Int            @db.SmallInt
  open_time             DateTime       @db.Time(6)
  close_time            DateTime       @db.Time(6)
  slot_duration_minutes Int            @default(60)
  is_active             Boolean?       @default(true)
  created_at            DateTime       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime       @default(now()) @db.Timestamptz(6)
  staff_member_id       String?        @db.Uuid
  businesses            businesses     @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff_members         staff_members? @relation(fields: [staff_member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, day_of_week], map: "idx_business_availability_business_day")
  @@index([business_id], map: "idx_business_availability_business_id")
  @@index([staff_member_id], map: "idx_business_availability_staff_member_id")
}

model bookings {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id     String         @db.Uuid
  customer_id     Int?
  service_name    String?        @db.VarChar(255)
  start_at        DateTime       @db.Timestamptz(6)
  end_at          DateTime       @db.Timestamptz(6)
  status          String         @default("confirmed") @db.VarChar(20)
  notes           String?
  created_via     String?        @default("whatsapp") @db.VarChar(20)
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime       @default(now()) @db.Timestamptz(6)
  staff_member_id String?        @db.Uuid
  service_id      String?        @db.Uuid
  businesses      businesses     @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers       customers?     @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  services        services?      @relation(fields: [service_id], references: [id], onUpdate: NoAction)
  staff_members   staff_members? @relation(fields: [staff_member_id], references: [id], onUpdate: NoAction)

  @@index([business_id], map: "idx_bookings_business_id")
  @@index([customer_id], map: "idx_bookings_customer_id")
  @@index([staff_member_id], map: "idx_bookings_staff_member_id")
  @@index([service_id], map: "idx_bookings_service_id")
  @@index([status], map: "idx_bookings_status")
  @@index([start_at], map: "idx_bookings_start_at")
  @@index([business_id, start_at], map: "idx_bookings_business_start")
  @@index([staff_member_id, business_id], map: "idx_bookings_staff_business")
}

model services {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id      String     @db.Uuid
  name             String     @db.VarChar(255)
  description      String?
  price            Decimal    @db.Decimal(12, 2)
  currency         String?    @default("COP") @db.VarChar(10)
  duration_minutes Int        @default(60)
  is_active        Boolean?   @default(true)
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  updated_at       DateTime   @default(now()) @db.Timestamptz(6)
  bookings         bookings[]
  businesses       businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, name], map: "idx_services_business_name")
  @@index([business_id], map: "idx_services_business_id")
  @@index([is_active], map: "idx_services_is_active")
}

model staff_members {
  id                    String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id           String                  @db.Uuid
  name                  String                  @db.VarChar(255)
  role                  String                  @db.VarChar(100)
  is_active             Boolean?                @default(true)
  user_id               String?                 @db.Uuid
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  bookings              bookings[]
  business_availability business_availability[]
  businesses            businesses              @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_staff_business")
  users                 users?                  @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "fk_staff_user")

  @@index([business_id, is_active], map: "idx_staff_business_active")
  @@index([business_id], map: "idx_staff_business_id")
  @@index([is_active], map: "idx_staff_is_active")
  @@index([user_id], map: "idx_staff_user_id")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model agent_types {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversation_sessions {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wa_id            String     @db.VarChar(50)
  business_id      String     @db.Uuid
  active_agents    Json?      @default("[]")
  order_context    Json?      @default("{}")
  booking_context  Json?      @default("{}")
  agent_contexts   Json?      @default("{}")
  last_activity_at DateTime   @default(now()) @db.Timestamptz(6)
  updated_at       DateTime   @default(now()) @db.Timestamptz(6)
  last_order_id    String?    @db.VarChar(50)
  last_booking_id  String?    @db.VarChar(50)
  businesses       businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([wa_id, business_id])
  @@index([last_activity_at], map: "idx_conversation_sessions_last_activity")
  @@index([wa_id, business_id], map: "idx_conversation_sessions_wa_business")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model processed_messages {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  message_id   String   @unique @db.VarChar(255)
  processed_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([processed_at], map: "idx_processed_at")
  @@index([message_id], map: "idx_processed_messages_message_id")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model business_customers {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id    String     @db.Uuid
  customer_id    Int
  name           String?    @db.VarChar(100)
  phone          String?    @db.VarChar(50)
  address        String?
  payment_method String?    @db.VarChar(100)
  notes          String?
  source         String     @default("auto") @db.VarChar(20)
  created_at     DateTime   @default(now()) @db.Timestamptz(6)
  updated_at     DateTime   @default(now()) @db.Timestamptz(6)
  businesses     businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers      customers  @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, customer_id], map: "uq_business_customers_pair")
  @@index([business_id], map: "idx_business_customers_business_id")
  @@index([customer_id], map: "idx_business_customers_customer_id")
}

model order_promotions {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id         String     @db.Uuid
  promotion_id     String     @db.Uuid
  promotion_name   String     @db.VarChar(120)
  pricing_mode     String     @db.VarChar(20)
  discount_applied Decimal    @db.Decimal(12, 2)
  applied_at       DateTime   @default(now()) @db.Timestamptz(6)
  orders           orders     @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  promotions       promotions @relation(fields: [promotion_id], references: [id], onUpdate: NoAction)

  @@index([order_id], map: "idx_order_promotions_order")
  @@index([promotion_id], map: "idx_order_promotions_promotion")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model promotion_components {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  promotion_id String     @db.Uuid
  product_id   String     @db.Uuid
  quantity     Int        @default(1) @db.SmallInt
  products     products   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  promotions   promotions @relation(fields: [promotion_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([promotion_id, product_id], map: "promotion_components_unique_product")
  @@index([promotion_id], map: "idx_promotion_components_promotion")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model promotions {
  id                   String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id          String                 @db.Uuid
  name                 String                 @db.VarChar(120)
  description          String?
  is_active            Boolean                @default(true)
  fixed_price          Decimal?               @db.Decimal(12, 2)
  discount_amount      Decimal?               @db.Decimal(12, 2)
  discount_pct         Int?                   @db.SmallInt
  days_of_week         Int[]                  @db.SmallInt
  start_time           DateTime?              @db.Time(6)
  end_time             DateTime?              @db.Time(6)
  starts_on            DateTime?              @db.Date
  ends_on              DateTime?              @db.Date
  created_at           DateTime               @default(now()) @db.Timestamptz(6)
  updated_at           DateTime               @default(now()) @db.Timestamptz(6)
  order_items          order_items[]
  order_promotions     order_promotions[]
  promotion_components promotion_components[]
  businesses           businesses             @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([business_id, is_active], map: "idx_promotions_business_active")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversation_daily_analyses {
  id                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id            String     @db.Uuid
  whatsapp_id            String     @db.VarChar(50)
  analysis_date          DateTime   @db.Date
  category               String     @db.VarChar(40)
  converted_to_order     Boolean    @default(false)
  order_id               String?    @db.Uuid
  had_human_intervention Boolean    @default(false)
  handoff_reason         String?
  message_count          Int        @default(0)
  first_msg_at           DateTime?  @db.Timestamptz(6)
  last_msg_at            DateTime?  @db.Timestamptz(6)
  summary                String?
  drop_off_reason        String?
  model                  String?    @db.VarChar(50)
  analyzed_at            DateTime   @default(now()) @db.Timestamptz(6)
  has_issues             Boolean    @default(false)
  businesses             businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders                 orders?    @relation(fields: [order_id], references: [id], onUpdate: NoAction)

  @@unique([business_id, whatsapp_id, analysis_date], map: "uq_daily_analysis_per_convo_per_day")
  @@index([business_id, analysis_date], map: "idx_conversation_daily_analyses_business_date")
  @@index([business_id], map: "idx_conversation_daily_analyses_business_id")
  @@index([category], map: "idx_conversation_daily_analyses_category")
  @@index([has_issues], map: "idx_conversation_daily_analyses_has_issues")
}

enum order_status {
  pending
  confirmed
  out_for_delivery
  ready_for_pickup
  completed
  cancelled
}
