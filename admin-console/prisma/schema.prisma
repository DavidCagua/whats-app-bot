generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model businesses {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @db.VarChar(255)
  business_type    String?           @default("barberia") @db.VarChar(50)
  settings         Json?             @default("{}")
  is_active        Boolean?          @default(true)
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @default(now()) @db.Timestamptz(6)
  user_businesses  user_businesses[]
  whatsapp_numbers whatsapp_numbers[]
  business_agents  business_agents[]
  products        products[]
  orders          orders[]

  @@index([is_active], map: "idx_businesses_is_active")
}

model business_agents {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id String    @db.Uuid
  agent_type  String    @db.VarChar(50)
  enabled     Boolean?  @default(true)
  priority    Int?      @default(100)
  config      Json?     @default("{}")
  created_by  String?   @db.Uuid
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, agent_type])
  @@index([business_id], map: "idx_business_agents_business_id")
  @@index([enabled], map: "idx_business_agents_enabled")
}

model conversation_agent_settings {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id   String   @db.Uuid
  whatsapp_id   String   @db.VarChar(50)
  agent_enabled Boolean? @default(true)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@unique([business_id, whatsapp_id])
  @@index([business_id], map: "idx_conversation_agent_settings_business_id")
  @@index([whatsapp_id], map: "idx_conversation_agent_settings_whatsapp_id")
  @@index([agent_enabled], map: "idx_conversation_agent_settings_agent_enabled")
}

model conversation_attachments {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id    Int
  type               String   @db.VarChar(20)
  content_type       String?  @db.VarChar(255)
  provider_media_url String?  @db.Text
  provider_media_id  String?  @db.VarChar(255)
  url                String?  @db.Text
  size_bytes         BigInt?
  duration_sec       Decimal? @db.Decimal(10, 2)
  transcript         String?  @db.Text
  provider_metadata  Json?    @default("{}")
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  updated_at         DateTime? @default(now()) @db.Timestamptz(6)
  conversations      conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id], map: "idx_conversation_attachments_conversation_id")
  @@index([type], map: "idx_conversation_attachments_type")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversations {
  id                 Int      @id @default(autoincrement())
  whatsapp_id        String   @db.VarChar(50)
  message            String
  message_type       String?  @default("text") @db.VarChar(20)
  role               String   @db.VarChar(20)
  timestamp          DateTime @db.Timestamp(6)
  created_at         DateTime @db.Timestamp(6)
  business_id        String   @db.Uuid
  whatsapp_number_id String?  @db.Uuid
  conversation_attachments conversation_attachments[]

  @@index([business_id], map: "idx_conversations_business_id")
  @@index([whatsapp_number_id], map: "idx_conversations_whatsapp_number_id")
  @@index([timestamp], map: "ix_conversations_timestamp")
  @@index([whatsapp_id], map: "ix_conversations_whatsapp_id")
}

model customers {
  id          Int      @id @default(autoincrement())
  whatsapp_id String   @unique(map: "ix_customers_whatsapp_id") @db.VarChar(50)
  name        String   @db.VarChar(100)
  age         Int?
  created_at  DateTime @db.Timestamp(6)
  updated_at  DateTime @db.Timestamp(6)
  orders      orders[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model user_businesses {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String     @db.Uuid
  business_id String     @db.Uuid
  role        String?    @default("staff") @db.VarChar(50)
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users       users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, business_id])
  @@index([business_id], map: "idx_user_businesses_business_id")
  @@index([user_id], map: "idx_user_businesses_user_id")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String            @unique @db.VarChar(255)
  password_hash   String
  full_name       String?           @db.VarChar(255)
  is_active       Boolean?          @default(true)
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?         @default(now()) @db.Timestamptz(6)
  role            String?           @default("staff") @db.VarChar(50)
  user_businesses user_businesses[]

  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model whatsapp_numbers {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id     String     @db.Uuid
  phone_number_id String?    @unique(map: "whatsapp_numbers_phone_number_id_key") @db.VarChar(255)
  phone_number    String     @db.VarChar(50)
  display_name    String?    @db.VarChar(255)
  is_active       Boolean?   @default(true)
  created_at      DateTime?  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?  @default(now()) @db.Timestamptz(6)
  businesses      businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([business_id, phone_number], map: "whatsapp_numbers_business_phone_unique")
  @@index([business_id], map: "idx_whatsapp_numbers_business_id")
  @@index([is_active], map: "idx_whatsapp_numbers_is_active")
  @@index([phone_number_id], map: "idx_whatsapp_numbers_phone_number_id")
}

model products {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id String    @db.Uuid
  name        String    @db.VarChar(255)
  description String?   @db.Text
  price       Decimal   @db.Decimal(12, 2)
  currency    String?   @default("COP") @db.VarChar(10)
  category    String?   @db.VarChar(50)
  sku         String?   @db.VarChar(50)
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  businesses  businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order_items order_items[]

  @@index([business_id], map: "idx_products_business_id")
  @@index([category], map: "idx_products_category")
  @@index([is_active], map: "idx_products_is_active")
}

model orders {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  business_id  String    @db.Uuid
  customer_id  Int?      @db.Integer
  whatsapp_id  String?   @db.VarChar(50)
  status       String?   @default("pending") @db.VarChar(20)
  total_amount Decimal   @default(0) @db.Decimal(12, 2)
  notes        String?   @db.Text
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
  businesses   businesses @relation(fields: [business_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers    customers? @relation(fields: [customer_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  order_items  order_items[]

  @@index([business_id], map: "idx_orders_business_id")
  @@index([customer_id], map: "idx_orders_customer_id")
  @@index([status], map: "idx_orders_status")
  @@index([created_at], map: "idx_orders_created_at")
}

model order_items {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String   @db.Uuid
  product_id String   @db.Uuid
  quantity   Int
  unit_price Decimal  @db.Decimal(12, 2)
  line_total Decimal  @db.Decimal(12, 2)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products   products @relation(fields: [product_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order_id")
  @@index([product_id], map: "idx_order_items_product_id")
}
