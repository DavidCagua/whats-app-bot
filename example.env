
# This token expires after 24 hours. You can get a new one from the your Meta App Dashboard > API Setup
# Or you can create an access token at the System User level from the Meta Business Settings: https://business.facebook.com/settings/system-users

ACCESS_TOKEN=""

APP_ID=""
APP_SECRET=""
RECIPIENT_WAID="" # Your WhatsApp number with country code (e.g., +31612345678)
VERSION="v18.0"
PHONE_NUMBER_ID=""

VERIFY_TOKEN=""

OPENAI_API_KEY=""
OPENAI_ASSISTANT_ID=""

# Database Configuration
DATABASE_URL=""  # PostgreSQL connection string from Supabase: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase Storage (for inbound media: voice, images, etc.)
# SUPABASE_URL="https://[project-ref].supabase.co"
# SUPABASE_SECRET_KEY=""  # Secret API key for server-side uploads (keep secret)

# Speech-to-text for voice messages (free tier: ~185h/month pre-recorded)
# Prefer AssemblyAI when set to avoid OpenAI Whisper cost; else falls back to OpenAI.
# ASSEMBLYAI_API_KEY=""  # Get from https://www.assemblyai.com/app/account

# Flask Configuration
FLASK_DEBUG="True"  # Set to "False" for production

# Admin -> Flask internal API (send message)
# Used by admin-console server-side route to call Flask
FLASK_API_BASE_URL=""  # e.g. https://whatsapp-bot-production.up.railway.app
# Shared secret used by admin-console and validated by Flask (X-Admin-API-Key)
ADMIN_API_KEY=""

# Tracing Configuration
TRACER_TYPE="console"  # Options: "console" (default) or "langfuse"
TRACE_LOG_PII="false"  # Set to "true" to log raw phone numbers and messages (DEBUG only, not recommended for production)

# Langfuse Configuration (optional, only needed if TRACER_TYPE=langfuse)
# LANGFUSE_SECRET_KEY=""
# LANGFUSE_PUBLIC_KEY=""
# LANGFUSE_HOST="https://cloud.langfuse.com"  # Optional, defaults to cloud

# Mock Mode (for local testing without Meta API access)
MOCK_MODE="false"  # Set to "true" to enable mock mode for local testing

# Railway – outbound voice notes need ffmpeg for WebM→OGG. The repo has nixpacks.toml
# so Nixpacks installs ffmpeg at build time. If you use Railpack instead, set
# RAILPACK_DEPLOY_APT_PACKAGES=ffmpeg in Railway Variables.

# Twilio (for /webhook/twilio - optional, only needed when using Twilio WhatsApp)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_NUMBER=""  # Your Twilio WhatsApp number (e.g. +14155238886)
# TWILIO_WEBHOOK_BASE_URL=""  # Public URL for signature validation when behind proxy (e.g. https://your-app.railway.app)